ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Supabase — required for suite persistence and auth
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here
SUPABASE_ENV=development
# JWT secret for verifying user tokens (Supabase > Project Settings > API > JWT Settings)
SUPABASE_JWT_SECRET=your_jwt_secret_here

# Crawl limits — override locally to crawl more pages (no Railway 300s timeout applies).
# Leave unset in Railway; these defaults keep the pipeline well under the 300s limit.
# MAX_PAGES=50          # local: crawl up to 50 pages
# MAX_DEPTH=3           # local: follow links 3 levels deep instead of 2
# MAX_TEMPLATE_REPS=3   # local: crawl 3 representatives per template (blog posts, locations, etc.)
